---
import { site } from '@/content/site';
---

<section id="founder" data-parallax="0.038" data-parallax-max="10">
  <div class="founder-inner" data-reveal="fade">
    <div class="founder-left">
      <div class="founder-photo-wrap">
        <div class="founder-photo-placeholder">
          <div class="icon">⊕</div>
          <div class="lbl">{site.founder.name} — Photo</div>
        </div>
      </div>
      <div class="founder-photo-note">Replace with your photo</div>
      <div class="section-label" style="margin-top:32px;">The Operator</div>
      <p class="founder-quote">
        I don't pitch<br />product development.<br />
        <em>I execute it.</em>
      </p>
      <div class="founder-sig">
        <div class="founder-name">{site.founder.name}</div>
        <div class="founder-role">{site.founder.role}</div>
      </div>
    </div>
    <div class="founder-right">
      <p style="font-size:16px; color:var(--muted); line-height:1.75; margin-bottom:32px;">
        {site.name} is a founder-led studio. Every engagement is run directly — no account managers, no handoffs, no diluted execution. You work with the person who built the products.
      </p>
      <p style="font-size:16px; color:var(--muted); line-height:1.75; margin-bottom:40px;">
        With a background spanning digital media and physical product development, the focus here is on one thing: making real products that reach real shelves. The studio has developed consumer goods across food &amp; beverage, supplements, and general consumer categories.
      </p>
      <div class="founder-credentials">
        <div class="cred-item">
          <div class="cred-icon"></div>
          <div class="cred-text"><strong>Founder-operated.</strong> No agency overhead. Direct execution.</div>
        </div>
        <div class="cred-item">
          <div class="cred-icon"></div>
          <div class="cred-text"><strong>20+ products executed</strong> across CPG, food, beverage, and consumer goods.</div>
        </div>
        <div class="cred-item">
          <div class="cred-icon"></div>
          <div class="cred-text"><strong>Fixed-scope model.</strong> You know exactly what you're paying for.</div>
        </div>
        <div class="cred-item">
          <div class="cred-icon"></div>
          <div class="cred-text"><strong>End-to-end capability.</strong> Strategy through manufacturing — under one roof.</div>
        </div>
      </div>
    </div>
  </div>
</section>
