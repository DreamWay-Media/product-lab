---
import { site } from '@/content/site';
---

<section id="cta" data-parallax="0.022" data-parallax-max="6">
  <span class="cta-watermark" aria-hidden="true">BUILD</span>
  <div class="cta-inner" data-reveal="fade">
    <div class="section-label" style="justify-content:center;">Ready to Build?</div>
    <h2 class="cta-h2">Let's Make<br /><span>Your Product.</span></h2>
    <p class="cta-sub">
      Book a free 30-minute strategy call. We'll review your idea, tell you if it's a fit, and outline exactly what a Product Sprint would look like for your specific product.
    </p>
    <a href={site.bookingUrl} class="btn-primary" style="font-size:14px; padding:20px 40px;">Book a Strategy Call →</a>
  </div>
</section>
