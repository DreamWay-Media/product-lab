<section id="process" data-parallax="0.04" data-parallax-max="10">
  <div class="process-inner">
    <div class="process-header" data-reveal="fade">
      <div>
        <div class="section-label">How It Works</div>
        <h2 class="section-h2" style="color:var(--white);">The Product<br /><span>Sprint.</span></h2>
      </div>
      <div class="process-timeline">
        <strong>6–10</strong>
        Weeks from kickoff<br />to launch-ready
      </div>
    </div>
    <div class="steps" data-reveal-group>
      <div class="step reveal-item" style="--i:0">
        <div class="step-num">Step 01</div>
        <div class="step-title">Strategy &amp; Definition</div>
        <p class="step-text">
          We map the product opportunity, define the target consumer, establish production feasibility, and set a clear go-to-market framework.
        </p>
        <div class="step-deliverable">↳ Product brief + market positioning</div>
      </div>
      <div class="step reveal-item" style="--i:1">
        <div class="step-num">Step 02</div>
        <div class="step-title">Brand &amp; Packaging</div>
        <p class="step-text">
          Identity, naming, visual language, and packaging design — built for shelf impact and manufacturing compliance from day one.
        </p>
        <div class="step-deliverable">↳ Brand system + print-ready packaging files</div>
      </div>
      <div class="step reveal-item" style="--i:2">
        <div class="step-num">Step 03</div>
        <div class="step-title">Sourcing &amp; Manufacturing</div>
        <p class="step-text">
          Supplier identification, quote collection, sample review, and manufacturing partner selection. We coordinate every moving part.
        </p>
        <div class="step-deliverable">↳ Qualified supplier + approved samples</div>
      </div>
      <div class="step reveal-item" style="--i:3">
        <div class="step-num">Step 04</div>
        <div class="step-title">Production Readiness</div>
        <p class="step-text">
          Final production specifications, quality standards, compliance documentation, and a full launch preparation package.
        </p>
        <div class="step-deliverable">↳ Production-ready product dossier</div>
      </div>
    </div>
  </div>
</section>
